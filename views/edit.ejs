<%- include('partials/header', { title: 'Edit Book' }) %>

<div class="form-page">
  <div class="form-header">
    <a href="/" class="back-link">← Back to Collection</a>
    <h1 class="form-title">Edit Book</h1>
    <p class="form-subtitle">Update the details for "<%= book.title %>"</p>
  </div>

  <% if (error) { %>
    <div class="alert alert-error">❌ <%= error %></div>
  <% } %>

  <form action="/books/<%= book._id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="book-form" novalidate>
    <div class="form-grid">

      <div class="form-section">
        <div class="form-group">
          <label for="title" class="form-label">Book Title <span class="required">*</span></label>
          <input
            type="text" id="title" name="title"
            class="form-control"
            value="<%= book.title %>"
            required maxlength="200"
          />
        </div>

        <div class="form-group">
          <label for="author" class="form-label">Author Name <span class="required">*</span></label>
          <input
            type="text" id="author" name="author"
            class="form-control"
            value="<%= book.author %>"
            required maxlength="100"
          />
        </div>

        <div class="form-group">
          <label for="category" class="form-label">Category <span class="required">*</span></label>
          <select id="category" name="category" class="form-control" required>
            <option value="">— Select Category —</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= book.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="price" class="form-label">Price (₹) <span class="required">*</span></label>
            <input
              type="number" id="price" name="price"
              class="form-control"
              value="<%= book.price %>"
              min="0" step="0.01" required
            />
          </div>
          <div class="form-group">
            <label for="quantity" class="form-label">Quantity <span class="required">*</span></label>
            <input
              type="number" id="quantity" name="quantity"
              class="form-control"
              value="<%= book.quantity %>"
              min="0" required
            />
          </div>
        </div>

        <div class="form-group">
          <label for="description" class="form-label">Description</label>
          <textarea
            id="description" name="description"
            class="form-control textarea"
            maxlength="1000"
            rows="4"
          ><%= book.description || '' %></textarea>
          <span class="char-count"><span id="descCount"><%= (book.description || '').length %></span>/1000</span>
        </div>
      </div>

      <div class="form-section">
        <div class="form-group">
          <label class="form-label">Book Cover Image</label>
          <div class="image-upload-zone" id="uploadZone">
            <input type="file" id="image" name="image" accept="image/*" class="file-input" />
            <div class="upload-preview" id="uploadPreview">
              <% if (book.image) { %>
                <img src="<%= book.image %>" alt="<%= book.title %>" class="current-cover" id="previewImg" />
                <div class="current-cover-label">Current cover — upload new to replace</div>
              <% } else { %>
                <div class="upload-placeholder">
                  <span class="upload-icon">🖼️</span>
                  <p class="upload-text">Click or drag to upload cover image</p>
                  <p class="upload-hint">JPEG, PNG, GIF, WEBP — Max 5MB</p>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <div class="book-id-info">
          <p><strong>Book ID:</strong> <code><%= book._id %></code></p>
          <p><strong>Added:</strong> <%= book.createdAt.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
          <p><strong>Last Updated:</strong> <%= book.updatedAt.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
        </div>
      </div>
    </div>

    <div class="form-footer">
      <a href="/books/<%= book._id %>" class="btn btn-ghost">Cancel</a>
      <form action="/books/<%= book._id %>?_method=DELETE" method="POST" class="inline-form" onsubmit="return confirmDelete('<%= book.title %>')">
        <button type="submit" class="btn btn-danger">🗑 Delete Book</button>
      </form>
      <button type="submit" class="btn btn-primary btn-lg">💾 Save Changes</button>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
